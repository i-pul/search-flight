ADDR=:8080

# Maximum time in milliseconds to wait for all provider responses (default: 2000)
PROVIDER_TIMEOUT_MS=2000

# Retry logic for failed provider calls
# RETRY_MAX_ATTEMPTS=1 disables retries entirely
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=100

# Best-value scoring weights (positive values; auto-normalised to sum to 1)
BEST_VALUE_WEIGHT_PRICE=0.50
BEST_VALUE_WEIGHT_DURATION=0.30
BEST_VALUE_WEIGHT_STOPS=0.20
